# Пример. Скопируйте в keys.env и заполните значения.
# Файл keys.env в .gitignore — не коммитится.

# --- RetailCRM ---
RETAILCRM_API_BASE=https://<your-subdomain>.retailcrm.ru/api/v5
RETAILCRM_API_KEY=
RETAILCRM_SITE=
# Если SSL-ошибка: 1
RETAILCRM_INSECURE_SSL=

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Если SSL к Supabase: 1
SUPABASE_INSECURE_SSL=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_INSECURE_SSL=
TELEGRAM_MIN_SUM_KZT=50000
TELEGRAM_POLL_SECONDS=30

